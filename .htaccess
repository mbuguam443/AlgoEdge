# AlgoEdge - Apache config for cPanel (algoedge.greatjourns.com)
# cPanel user: greatjou | App root: /home/greatjou/algoedge/

# Disable directory listing
Options -Indexes

# Handle Python app via Passenger
PassengerEnabled On
PassengerAppRoot /home/greatjou/algoedge
PassengerPython /home/greatjou/virtualenv/algoedge/bin/python

# Serve static files directly (performance)
Alias /static/ /home/greatjou/algoedge/staticfiles/
<Directory /home/greatjou/algoedge/staticfiles>
    Require all granted
</Directory>

Alias /media/ /home/greatjou/algoedge/media/
<Directory /home/greatjou/algoedge/media>
    Require all granted
</Directory>

# Block access to sensitive files
<FilesMatch "\.(py|pyc|sqlite3|env|gitignore|md|txt)$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP:X-Forwarded-Proto} !https
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Block direct access to Django app directories
    RewriteRule ^(algoedge|home|userauth|learn|shop|cservice|articles|dash|copytrade|pfarm|automate|brokerx|refer|alerts|paygate|metrics)/ - [F,L]
</IfModule>

# Gzip
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    Compress image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
</IfModule>
