# Django
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com,.railway.app
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://*.onrender.com
SITE_URL=http://localhost:8000

# Database (leave blank for SQLite dev, set for PostgreSQL prod)
DATABASE_URL=

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For production use SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@algoedge.com

# Payments
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=

# M-Pesa
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=

# Links
BROKER_AFFILIATE_LINK=https://your-broker-affiliate-link.com
