# Django
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.yourdomain.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000,https://*.yourdomain.com
SITE_URL=https://yourdomain.com
DJANGO_SECURE_SSL=True

# MySQL Database (cPanel / phpMyAdmin)
DB_NAME=your_database_name
DB_USER=your_database_username
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_PORT=3306

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@algoedge.com

# Payments
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
PAYPAL_CLIENT_ID=

# M-Pesa
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=

# Links
BROKER_AFFILIATE_LINK=https://your-broker-affiliate-link.com
DISCORD_INVITE_LINK=https://discord.gg/your-invite
